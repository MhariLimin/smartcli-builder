{
  "name": "smartcli-web",
  "private": true,
  "version": "0.1.0",
  "description": "Root tooling for smartcli-web: one-command dev runner for backend + frontend.",
  "scripts": {
    "postinstall": "cd smartcli-web-frontend && npm install",
    "dev:backend": "cd smartcli-web-backend && mvn spring-boot:run",
    "dev:frontend": "cd smartcli-web-frontend && npm run dev",
    "dev": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors cyan.bold,green.bold \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build:frontend": "cd smartcli-web-frontend && npm run build",
    "build:backend": "cd smartcli-web-backend && mvn -DskipTests package"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
